{
  "project": {
    "name": "lerobot-iot",
    "environment": "dev",
    "region": "us-east-1"
  },
  "iot": {
    "deviceId": "arm-001",
    "topicPrefix": "dt/lerobot"
  },
  "component": {
    "name": "com.lerobot.telemetry",
    "version": "2.2.0",
    "pollingRateHz": 10,
    "serialPort": "/dev/ttyACM2",
    "mockMode": false,
    "serialBaudRate": 1000000,
    "serialTimeout": 0.1,
    "tempWarningThreshold": 50,
    "mode": "ros2"
  },
  "ros2": {
    "nodeName": "lerobot_telemetry",
    "jointStatesTopic": "/joint_states",
    "servoDiagnosticsTopic": "/servo_diagnostics",
    "distro": "jazzy"
  },
  "greengrass": {
    "nucleusVersion": "2.16.1"
  },
  "infrastructure": {
    "stackName": "LeRobotIotStack"
  }
}
